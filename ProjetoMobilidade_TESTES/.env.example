# ─── Configuração do Supabase ───────────────────────────────────────────────────
# IMPORTANTE: Este é um arquivo de exemplo. Crie um arquivo .env na raiz do projeto
# com suas credenciais reais. NUNCA faça commit do arquivo .env!

# Formato: postgresql://usuario:senha@host:porta/banco_dados
DATABASE_URL=postgresql://postgres:sua_senha_aqui@db.seu_projeto.supabase.co:5432/postgres

# ─── Configuração de E-mail (Obrigatório) ──────────────────────────────────────
# E-mail corporativo para envio de cartas
EMAIL_REMETENTE=seu_email@renapsi.org.br

# Senha de aplicação (gerar em https://account.microsoft.com/security)
EMAIL_SENHA=sua_senha_aplicacao_aqui

# ─── Configuração de API Gemini (Obrigatório) ──────────────────────────────────
# Chave de API do Google Gemini (gerar em https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=sua_chave_api_gemini_aqui

# ─── Encriptação de Dados Sensíveis (Obrigatório) ────────────────────────────
# Gerar com: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=sua_chave_encriptacao_aqui

# ─── Configuração de Logging (Opcional) ────────────────────────────────────────
LOG_LEVEL=INFO

# ─── Configuração de Ambiente (Opcional) ────────────────────────────────────────
ENVIRONMENT=development
# Valores: development, staging, production

